#include <GL/glut.h>

void display() {

    glClear(GL_COLOR_BUFFER_BIT);

    glPointSize(5.0);
    glBegin(GL_POINTS);

        glColor3f(1.0, 1.0, 1.0);

        glVertex2f(-0.8, 0.7);
        glVertex2f(-0.5, 0.6);
        glVertex2f(-0.2, 0.8);
        glVertex2f(0.1, 0.7);
        glVertex2f(0.4, 0.6);
        glVertex2f(0.7, 0.8);
        glVertex2f(-0.6, 0.3);
        glVertex2f(-0.3, 0.4);
        glVertex2f(0.2, 0.5);
        glVertex2f(0.6, 0.4);

    glEnd();

    glLineWidth(3.0);
    glBegin(GL_LINES);

        glColor3f(0.0, 1.0, 0.0);

        glVertex2f(-1.0, -0.2);
        glVertex2f(1.0, -0.2);

    glEnd();

    glFlush();
}



int main(int argc, char** argv){

    glutInit(&argc, argv);
    glutInitDisplayMode(GLUT_SINGLE | GLUT_RGB);
    glutInitWindowSize(600,600);
    glutCreateWindow("Langit Berbintang");

    glClearColor(0.0, 0.0, 0.2, 1.0);

    glutDisplayFunc(display);

    glutMainLoop();
}
